APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Central app DB (tenants table, landlord users). Use a name that is never the same as a tenant's MySQL database.
# If unset, landlord falls back to DB_* above. See LANDLORD_DB_* in config/database.php.
# LANDLORD_DB_DATABASE=laravel_central

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=pk_test_your_key_here
STRIPE_SECRET=sk_test_your_secret_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# System updates (typically central app — serves /system-updates/check and download)
# APP_RELEASE_VERSION=1.0.0
# CENTRAL_UPDATE_VERSION=1.0.0
# CENTRAL_UPDATE_NOTES=
# CENTRAL_UPDATE_PUBLISHED_AT=
# CENTRAL_UPDATE_PACKAGE_FILENAME=latest-update.zip
# CENTRAL_UPDATE_CHANNEL_TOKEN=
# CENTRAL_UPDATE_BASE_URL=

# GitHub Releases API for update metadata (optional; set on central only). Repo format: owner/repo
# CENTRAL_GITHUB_REPO=your-org/your-repo
# Optional: release attachment filename (exact or substring) when multiple assets exist
# CENTRAL_GITHUB_RELEASE_ASSET=my-app.zip
#
# CENTRAL_GITHUB_TOKEN= (optional for public repos; required for private + higher rate limits)
# Create a token: GitHub → Settings → Developer settings → Personal access tokens
#   Fine-grained: https://github.com/settings/personal-access-tokens — add repo, Contents: Read, Metadata: Read
#   Classic: https://github.com/settings/tokens — enable "repo" for private repositories
# CENTRAL_GITHUB_TOKEN=
#
# CENTRAL_GITHUB_CACHE_TTL=300
